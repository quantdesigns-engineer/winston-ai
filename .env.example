# Winston Environment Variables

# Server
PORT=57710
FRONTEND_PORT=57711

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
# Channel ID for ops notifications (startup, shutdown, frontend down)
SLACK_NOTIFY_CHANNEL=C0123456789

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id

# Kali VM — SSH connectivity for pentester agent
# KALI_VM_HOST: IP or hostname of the Kali Linux VM (e.g. 192.168.1.100)
KALI_VM_HOST=192.168.1.100
# KALI_VM_USER: SSH username on the Kali VM (default: kali)
KALI_VM_USER=kali
# KALI_VM_SSH_KEY: Path to the SSH private key for passwordless auth (e.g. ~/.ssh/kali_vm)
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/kali_vm && ssh-copy-id -i ~/.ssh/kali_vm kali@<host>
KALI_VM_SSH_KEY=~/.ssh/kali_vm

# YouTube
YOUTUBE_API_KEY=your-youtube-api-key

# Nano Banana
NANO_BANANA_API_KEY=your-nano-banana-key

# Google MCP (for marketing agent)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Jobs pipeline (see docs/JOBS_PIPELINE.md)
# WINSTON_JOBS_DB defaults to ~/.claude/data/jobs.db
# WINSTON_JOBS_DB=/absolute/path/to/jobs.db
# WINSTON_JOBS_TOOLS_DIR defaults to ~/.claude/tools/jobs
# WINSTON_JOBS_TOOLS_DIR=/absolute/path/to/jobs/tools
# WINSTON_DRIVE_CREDS_FILE: filename inside ~/.google_workspace_mcp/credentials/
# WINSTON_DRIVE_CREDS_FILE=your-email@gmail.com.json
